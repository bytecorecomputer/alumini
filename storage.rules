rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. Allow public read access (essential for QR codes, profile pics, certificates)
    match /{allPaths=**} {
      allow read: if true;
    }

    // 2. Certificates: Only admins can upload
    match /certificates/{fileName} {
      allow write: if request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // 3. Profile Phots: Authenticated users can upload
    match /students/{allPaths=**} {
      allow write: if request.auth != null;
    }

    // 4. General fallback: Deny anything not explicitly allowed
    match /{allPaths=**} {
      allow write: if false;
    }
  }
}
