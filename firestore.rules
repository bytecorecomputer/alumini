rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. User Profiles: Users can read/write their OWN data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Students: Public read (for login/directory), Restricted write
    match /students/{studentId} {
      allow get, list: if true; 
      // Allow updates only to photoUrl and updatedAt to prevent tampering with fees or course data
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoUrl', 'updatedAt']); 
      // Full write still requires admin role
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // 3. Certificates: Public read (verification), Staff write
    match /certificates/{certId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 4. Metadata and Courses: Public read, Admin write
    match /metadata/{docId} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }
    match /courses/{courseId} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }
    
    // 5. Lab Gallery: Public Read, Admin Write
    match /lab_gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // 6. Coaching: Public Read, Admin Write
    match /coaching/{docId} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    match /quiz_progress/{studentId} {
      allow read: if true;
      allow create: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['courses', 'lastActive', 'modules']) || 
                    (request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // 8. Experts Management
    match /experts/{expertId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // 9. Live Quizzes (Real-time Multiplayer)
    match /live_quizzes/{roomId} {
      allow read: if true; // Anyone can join and read
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
      
      // Subcollection for participants
      match /participants/{participantId} {
         allow read: if true;
         allow create: if true;
         allow update: if request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastAnswer', 'score', 'lastPoints', 'joinedAt', 'name']);
         allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
      }
    }

    // 10. Default restrictive fallback (Best Practice)
    // Only allow access if explicitly defined above
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
